"""
main.py — Web Application Vulnerability Scanner

Scans web applications for OWASP Top 10 vulnerabilities:
- A03:2021 - Injection (SQL Injection, XSS)
- A05:2021 - Security Misconfiguration (headers, sensitive files)

Usage:
    python main.py --url http://localhost:8080 --format html -v
    python main.py --url http://dvwa.local --depth 2 --modules sqli,xss,headers
    python main.py --url http://target.com --cookie "PHPSESSID=abc123" -o report
"""
import sys
import os
import time
import argparse
from datetime import datetime
from urllib.parse import urlparse

sys.path.insert(0, os.path.dirname(__file__))

import requests
from modules.crawler import WebCrawler
from modules.header_auditor import HeaderAuditor
from modules.sql_injection import SQLiScanner
from modules.xss_scanner import XSSScanner
from modules.info_disclosure import InfoDisclosureScanner
from modules.false_positive_filter import FalsePositiveFilter
from utils.logger import get_logger, configure_root
from utils.config import load_config
from utils.mitre import get_dict as mitre_get

log = get_logger(__name__)

try:
    from colorama import Fore, Style, init as colorama_init
    colorama_init(autoreset=True)
    C_GREEN = Fore.GREEN
    C_RED = Fore.RED
    C_YELLOW = Fore.YELLOW
    C_CYAN = Fore.CYAN
    C_BOLD = Style.BRIGHT
    C_RESET = Style.RESET_ALL
except ImportError:
    C_GREEN = C_RED = C_YELLOW = C_CYAN = C_BOLD = C_RESET = ""

VERSION = "1.0.0"
BANNER = f"""
{C_CYAN}{C_BOLD}
  ╔══════════════════════════════════════════════════════╗
  ║       Web Application Vulnerability Scanner  v{VERSION}  ║
  ║       OWASP Top 10 · SQLi · XSS · Headers          ║
  ║       AUTHORIZED TESTING ONLY                       ║
  ╚══════════════════════════════════════════════════════╝
{C_RESET}"""

SEVERITY_COLORS = {
    "CRITICAL": C_RED + C_BOLD,
    "HIGH": C_RED,
    "MEDIUM": C_YELLOW,
    "LOW": C_GREEN,
    "INFORMATIONAL": C_CYAN,
}

ALL_MODULES = ["headers", "sqli", "xss", "info"]


def build_session(args: argparse.Namespace) -> requests.Session:
    """Configure a requests.Session from CLI args."""
    session = requests.Session()
    session.verify = False  # Many test environments use self-signed certs
    session.headers.update({
        "User-Agent": f"WebVulnScanner/{VERSION} (security-testing)",
    })
    if args.cookie:
        for cookie in args.cookie.split(";"):
            if "=" in cookie:
                name, _, value = cookie.strip().partition("=")
                session.cookies.set(name.strip(), value.strip())
    if args.header:
        for h in args.header:
            if ":" in h:
                name, _, value = h.partition(":")
                session.headers[name.strip()] = value.strip()
    return session


def run_scan(args: argparse.Namespace) -> int:
    print(BANNER)
    log.info("Target : %s", args.url)
    log.info("Modules: %s", ", ".join(args.modules))
    print()

    session = build_session(args)
    all_findings = []
    start_time = time.time()

    common_opts = dict(
        session=session,
        target_url=args.url,
        verbose=args.verbose,
        timeout=args.timeout,
        delay=args.delay,
    )

    # ── Phase 1: Header Audit (fast, no crawling needed) ──────────────────
    if "headers" in args.modules:
        print(f"{C_CYAN}[1/4] Checking security headers...{C_RESET}")
        scanner = HeaderAuditor(**common_opts)
        findings = scanner.scan()
        all_findings.extend(findings)
        print(f"      {C_GREEN}Found {len(findings)} header issue(s){C_RESET}")

    # ── Phase 2: Information Disclosure ───────────────────────────────────
    if "info" in args.modules:
        print(f"{C_CYAN}[2/4] Probing for information disclosure...{C_RESET}")
        scanner = InfoDisclosureScanner(**common_opts)
        findings = scanner.scan()
        all_findings.extend(findings)
        print(f"      {C_GREEN}Found {len(findings)} disclosure issue(s){C_RESET}")

    # ── Phase 3: Crawl (needed for SQLi and XSS) ─────────────────────────
    forms = []
    url_params = []
    if any(m in args.modules for m in ("sqli", "xss")):
        print(f"{C_CYAN}[3/4] Crawling target (depth={args.depth}, max={args.max_pages} pages)...{C_RESET}")
        crawler = WebCrawler(
            base_url=args.url,
            session=session,
            max_depth=args.depth,
            max_pages=args.max_pages,
            timeout=args.timeout,
            delay=args.delay,
            verbose=args.verbose,
        )
        urls, forms = crawler.crawl()
        url_params = crawler.extract_url_params(urls)
        print(f"      {C_GREEN}Discovered {len(urls)} URL(s), {len(forms)} form(s), "
              f"{len(url_params)} URL parameter(s){C_RESET}")

    # ── Phase 4: Injection Testing ────────────────────────────────────────
    if "sqli" in args.modules:
        print(f"{C_CYAN}[4a/4] Testing for SQL Injection...{C_RESET}")
        scanner = SQLiScanner(**common_opts)
        scanner.scan_forms(forms)
        scanner.scan_url_params(url_params)
        all_findings.extend(scanner.findings)
        print(f"      {C_GREEN}Found {len(scanner.findings)} SQLi issue(s){C_RESET}")

    if "xss" in args.modules:
        print(f"{C_CYAN}[4b/4] Testing for Reflected XSS...{C_RESET}")
        scanner = XSSScanner(**common_opts)
        scanner.scan_forms(forms)
        scanner.scan_url_params(url_params)
        all_findings.extend(scanner.findings)
        print(f"      {C_GREEN}Found {len(scanner.findings)} XSS issue(s){C_RESET}")

    elapsed = time.time() - start_time
    log.info("Scan completed in %.1fs", elapsed)

    # ── Attach MITRE ATT&CK context ───────────────────────────────────────
    _mitre_map = {
        "sql": mitre_get("sql_injection"),
        "xss": mitre_get("xss"),
        "header": mitre_get("info_disclosure"),
        "info": mitre_get("info_disclosure"),
        "path": mitre_get("path_traversal"),
    }
    for f in all_findings:
        title_lower = f.get("title", "").lower()
        for key, mitre_data in _mitre_map.items():
            if key in title_lower and mitre_data:
                f.setdefault("mitre", mitre_data)
                break

    # ── False-positive filtering ──────────────────────────────────────────
    cfg = load_config()
    if cfg.get("false_positive.enabled", True):
        fp_filter = FalsePositiveFilter(
            min_body_diff=cfg.get("false_positive.min_body_diff_bytes", 50),
            reflection_threshold=cfg.get("false_positive.reflection_threshold", 0.8),
        )
        confirmed, filtered_out = fp_filter.filter_findings(all_findings)
        if filtered_out:
            log.debug("False-positive filter removed %d finding(s)", len(filtered_out))
        all_findings = confirmed

    # ── Summary ───────────────────────────────────────────────────────────
    counts = {}
    for f in all_findings:
        sev = f.get("severity", "LOW")
        counts[sev] = counts.get(sev, 0) + 1

    log.info("\n%s── Findings Summary ───────────────────────────────────%s", C_BOLD, C_RESET)
    log.info("  Total: %d", len(all_findings))
    for sev in ("CRITICAL", "HIGH", "MEDIUM", "LOW", "INFORMATIONAL"):
        c = counts.get(sev, 0)
        if c > 0:
            color = SEVERITY_COLORS.get(sev, "")
            log.info("  %s%-15s%d%s", color, sev, c, C_RESET)
    print()

    # ── Output ────────────────────────────────────────────────────────────
    _write_output(all_findings, args)

    return 1 if any(f["severity"] in ("CRITICAL", "HIGH") for f in all_findings) else 0


def _default_output_base(target_url: str) -> str:
    """
    Build the default output base path: output/scan_<hostname>_<timestamp>
    Creates the output/ directory if it does not exist.
    """
    hostname = urlparse(target_url).hostname or "target"
    # Replace characters that are invalid in filenames on Windows/Linux
    hostname = hostname.replace(":", "_").replace("/", "_")
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), "output")
    os.makedirs(out_dir, exist_ok=True)
    return os.path.join(out_dir, f"scan_{hostname}_{ts}")


def _write_output(findings, args):
    """Write findings to the output/ folder. Always runs after every scan."""
    from reporter import JsonReporter, HtmlReporter, MarkdownReporter

    fmt  = args.format
    base = args.output if args.output else _default_output_base(args.url)
    data = {
        "target":         args.url,
        "total_findings": len(findings),
        "findings":       findings,
    }

    if fmt in ("json", "all"):
        path = JsonReporter().save(data, f"{base}.json")
        log.info("%s[+] JSON report: %s%s", C_GREEN, path, C_RESET)

    if fmt in ("html", "all"):
        path = HtmlReporter().save(data, f"{base}.html")
        log.info("%s[+] HTML report: %s%s", C_GREEN, path, C_RESET)

    if fmt in ("text", "markdown", "all"):
        path = MarkdownReporter().save(data, f"{base}.md")
        log.info("%s[+] Markdown:    %s%s", C_GREEN, path, C_RESET)


def _write_html_report(findings, target_url, output_path):
    """Generate a self-contained HTML report."""
    sev_colors = {
        "CRITICAL": "#dc2626", "HIGH": "#ea580c",
        "MEDIUM": "#d97706", "LOW": "#16a34a", "INFORMATIONAL": "#2563eb",
    }
    counts = {}
    for f in findings:
        sev = f.get("severity", "LOW")
        counts[sev] = counts.get(sev, 0) + 1

    # Inline SVG bar chart
    max_count = max(counts.values()) if counts else 1
    bar_width = 200
    svg_bars = []
    y = 0
    for sev in ("CRITICAL", "HIGH", "MEDIUM", "LOW"):
        c = counts.get(sev, 0)
        w = int((c / max_count) * bar_width) if max_count > 0 else 0
        color = sev_colors.get(sev, "#999")
        svg_bars.append(
            f'<rect x="80" y="{y * 25 + 5}" width="{w}" height="18" fill="{color}"/>'
            f'<text x="75" y="{y * 25 + 18}" text-anchor="end" '
            f'font-size="12" fill="#1e293b">{sev}</text>'
            f'<text x="{80 + w + 5}" y="{y * 25 + 18}" font-size="12" fill="#64748b">{c}</text>'
        )
        y += 1

    bars_svg = "\n".join(svg_bars)
    svg_height = y * 25 + 20

    findings_html = []
    for i, f in enumerate(findings, 1):
        color = sev_colors.get(f.get("severity", "LOW"), "#999")
        findings_html.append(f"""
        <div class="finding">
          <div class="finding-header" style="border-left: 4px solid {color}">
            <span class="badge" style="background:{color}">{f.get('severity','?')}</span>
            <strong>[F{i:03d}] {f.get('title','')}</strong>
            <span class="owasp">{f.get('owasp_id','')}</span>
          </div>
          <div class="finding-body">
            <p><strong>URL:</strong> <code>{f.get('url','')}</code></p>
            <p><strong>Description:</strong> {f.get('description','')}</p>
            <p><strong>Evidence:</strong> <code>{f.get('evidence','')}</code></p>
            <p><strong>Recommendation:</strong> {f.get('recommendation','')}</p>
          </div>
        </div>""")

    html = f"""<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8">
<title>Web Vulnerability Scan Report — {target_url}</title>
<style>
body{{font-family:system-ui,sans-serif;max-width:1000px;margin:auto;padding:24px;color:#1e293b;background:#f8fafc}}
h1{{color:#0f172a;border-bottom:2px solid #e2e8f0;padding-bottom:8px}}
h2{{color:#334155;margin-top:32px}}
.summary{{background:#1e293b;color:#f8fafc;padding:20px;border-radius:8px;margin:16px 0}}
.finding{{background:#fff;border:1px solid #e2e8f0;border-radius:6px;margin:12px 0;overflow:hidden}}
.finding-header{{padding:12px 16px;background:#f8fafc;display:flex;align-items:center;gap:12px}}
.finding-body{{padding:12px 16px}}
.badge{{padding:3px 8px;border-radius:4px;color:white;font-size:12px;font-weight:bold}}
.owasp{{margin-left:auto;color:#64748b;font-size:12px}}
code{{background:#f1f5f9;padding:2px 4px;border-radius:3px;font-family:monospace;word-break:break-all}}
@media print{{body{{background:white}}.summary{{background:#1e293b}}}}
</style></head><body>
<h1>Web Vulnerability Scan Report</h1>
<div class="summary">
  <strong>Target:</strong> {target_url}<br>
  <strong>Total Findings:</strong> {len(findings)}<br>
  <br>
  <svg width="300" height="{svg_height}" style="background:transparent">
    {bars_svg}
  </svg>
</div>
<h2>Findings ({len(findings)})</h2>
{''.join(findings_html) if findings_html else '<p><em>No vulnerabilities found.</em></p>'}
<hr><p style="color:#94a3b8;font-size:12px">
Generated by Web Vulnerability Scanner v{VERSION} — Authorized testing only.
</p></body></html>"""

    with open(output_path, "w", encoding="utf-8") as fh:
        fh.write(html)


def _write_text_report(findings, output_path):
    lines = [f"Web Vulnerability Scan — {len(findings)} finding(s)\n", "=" * 60]
    for i, f in enumerate(findings, 1):
        lines += [
            f"\n[{i:03d}] {f.get('severity','?')} — {f.get('title','')}",
            f"  URL: {f.get('url','')}",
            f"  OWASP: {f.get('owasp_id','')}",
            f"  {f.get('description','')}",
            f"  Evidence: {f.get('evidence','')}",
            f"  Fix: {f.get('recommendation','')}",
        ]
    with open(output_path, "w", encoding="utf-8") as fh:
        fh.write("\n".join(lines))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="web-vuln-scanner",
        description="OWASP Top 10 Web Application Vulnerability Scanner",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  python main.py --url http://localhost:8080 -v --format html -o scan_report
  python main.py --url http://dvwa.local --cookie "security=low; PHPSESSID=abc" --modules sqli,xss
  python main.py --url http://target.com --depth 3 --max-pages 100
        """
    )
    parser.add_argument("--url", "-u", required=True, help="Target URL (e.g. http://localhost:8080)")
    parser.add_argument("--modules", default="all",
                        help=f"Comma-separated modules to run (default: all). Options: {','.join(ALL_MODULES)}")
    parser.add_argument("--depth", type=int, default=2, help="Crawler depth (default: 2)")
    parser.add_argument("--max-pages", type=int, default=50, dest="max_pages",
                        help="Maximum pages to crawl (default: 50)")
    parser.add_argument("--timeout", type=int, default=10,
                        help="HTTP request timeout in seconds (default: 10)")
    parser.add_argument("--delay", type=float, default=0.0,
                        help="Delay between requests in seconds (default: 0)")
    parser.add_argument("--cookie", help="Session cookie string (e.g. 'PHPSESSID=abc; security=low')")
    parser.add_argument("--header", action="append", metavar="NAME:VALUE",
                        help="Extra HTTP header (can be specified multiple times)")
    parser.add_argument("-o", "--output",
                        help="Output file base path (no extension). "
                             "Default: output/scan_<host>_<timestamp>")
    parser.add_argument("--format", choices=["html", "json", "text", "all"], default="html",
                        help="Output format (default: html)")
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    configure_root(verbose=args.verbose)

    # Parse modules
    if args.modules == "all":
        args.modules = ALL_MODULES
    else:
        args.modules = [m.strip().lower() for m in args.modules.split(",")]
        invalid = set(args.modules) - set(ALL_MODULES)
        if invalid:
            log.error("Unknown modules: %s. Valid: %s", invalid, ALL_MODULES)
            return 1

    # Suppress InsecureRequestWarning for test environments
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

    return run_scan(args)


if __name__ == "__main__":
    sys.exit(main())
